{
  "name": "magic-context-animation30",
  "version": "1.0.0",
  "description": "Remotion animation for OpenCode Magic Context - 91 seconds at 30fps",
  "private": true,
  "scripts": {
    "studio": "npx remotion studio",
    "render": "npx remotion render MagicContextAnimation out/magic-context-30fps.mp4",
    "render:gif": "npx remotion render MagicContextAnimation out/magic-context.gif --codec=gif",
    "render:webm": "npx remotion render MagicContextAnimation out/magic-context.webm --codec=vp9"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.290"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "^5.0.0"
  }
}
